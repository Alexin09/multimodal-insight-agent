# ── LLM Provider ──────────────────────────────────────────
# OpenAI-compatible API (supports Kimi, DeepSeek, OpenAI, Ollama, vLLM, etc.)
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=kimi-k2.5

# Set to "mock" to use mock LLM responses (no API key needed)
# Set to "openai" to use real LLM API
LLM_MODE=openai

# ZhipuAI GLM-OCR (optional, for image text extraction)
ZHIPU_API_KEY=your-zhipu-api-key-here

# ── Database (MCP) ───────────────────────────────────────
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=public

# Set to "mcp" to use PostgreSQL via MCP, "sqlite" for local demo
DB_MODE=sqlite

# ── MCP Settings ─────────────────────────────────────────
QUERY_TIMEOUT=60
MAX_ROWS=500

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
